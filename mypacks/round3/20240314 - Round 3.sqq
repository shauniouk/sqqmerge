<?xml version="1.0" encoding="utf-8"?><round><game>Keypad Quiz</game><title>SQQ Merge Packer</title><points_per_question>4</points_per_question><go_wide>false</go_wide><speed_bonus>true</speed_bonus><questions><question><user_view>letters</user_view><q>Movie: What is real name of Baby's character in "Dirty Dancing"? </q><short_answer>F</short_answer><long_answer>Frances</long_answer><id>5692390</id></question><question><user_view>letters</user_view><q>Movie: What well-known actress only made it into the first few minutes of "Scream"? </q><short_answer>D</short_answer><long_answer>Drew Barrymore</long_answer><picture></picture><id>5692399</id></question><question><user_view>sequence</user_view><q>Movie: Who wrote the title song for "Footloose"? </q><short_answer/><long_answer>Kenny Loggins</long_answer><options><option>ke</option><option>nny</option><option>lo</option><option>g</option><option>gi</option><option>ns</option></options><id>5692395</id></question><question><user_view>multi</user_view><q>Movie: Grease was released in 1978 but was set in which year? </q><short_answer>D</short_answer><long_answer/><options><option>1942</option><option>1948</option><option>1952</option><option>1958</option><option>1962</option><option>1968</option></options><id>5692411</id></question><question><user_view>numbers</user_view><q>Movie: What is Troy's Basketball number in High School Musical? </q><short_answer>14</short_answer><long_answer/><id>5185148</id></question><question><user_view>numbers</user_view><q>Musical: How many letters are there in supercalifragilisticexpialidocious? </q><short_answer>34</short_answer><long_answer>supercalifragilisticexpialidocious</long_answer><id>5744108</id></question><question><user_view>multi</user_view><q>Musical: Which musical is based on a 1995 Gregory Maguire novel which is an alternative telling of The Wizard of Oz? </q><short_answer>E</short_answer><long_answer/><options><option>Evita</option><option>Billy Elliot</option><option>Chess</option><option>Legally Blonde</option><option>Wicked</option></options><id>5744117</id></question><question><user_view>letters</user_view><q>Musical: Who is this? </q><short_answer>A</short_answer><long_answer>Andrew Lloyd Webber</long_answer><picture></picture><id>5744121</id></question><question><user_view>multi</user_view><q>Body: Approx. How many MILES of blood vessels are there in the human body? </q><short_answer>C</short_answer><long_answer>that's more than twice the distance around the world.</long_answer><options><option>1600</option><option>6000</option><option>60,000</option><option>600,000</option></options><id>5737154</id></question><question><user_view>letters</user_view><q>Body: What is the name of the substance that the body over-produces in an allergic reaction to pollen? </q><short_answer>H</short_answer><long_answer>Histamine -  which is why we tend to take anti-Histamines to relieve the symptoms</long_answer><id>5736978</id></question><question><user_view>multi</user_view><q>Body: What is the white part of the eye called? </q><short_answer>D</short_answer><long_answer/><options><option>Cornea</option><option>Macula</option><option>Retina</option><option>Sclera</option></options><id>5737005</id></question><question><user_view>letters</user_view><q>Sport: What is the nickname for Arsenal FC? </q><short_answer>G</short_answer><long_answer>The Gunners</long_answer></question><question><user_view>letters</user_view><q>Sport: Which boxer did Muhammad Ali fight in 'The Rumble in the Jungle'? </q><short_answer>G</short_answer><long_answer>George Foreman</long_answer></question><question><user_view>letters</user_view><q>Sport: Which French city is known for its 24 hour motor race? </q><short_answer>L</short_answer><long_answer>Le Mans</long_answer></question><question><user_view>letters</user_view><q>Sport: What is the term for a score of 1 over par on a golf hole? </q><short_answer>B</short_answer><long_answer>Bogey</long_answer></question><question><user_view>letters</user_view><q>Sport: Which snooker player has also written crime fiction novels called 'Framed', 'Double Kiss' and 'The Break'? </q><short_answer>R</short_answer><long_answer>Ronnie O'Sullivan</long_answer></question><question><user_view>letters</user_view><q>Oscars: Which film won Best Picture at the 2024 Oscars? </q><short_answer>O</short_answer><long_answer>Oppenheimer</long_answer></question><question><user_view>multi</user_view><q>Oscars: Who hosted the 2024 Oscars? </q><short_answer>B</short_answer><long_answer/><options><option>Chris Rock</option><option>Jimmy Kimmel</option><option>Seth MacFarlane</option><option>Amy Schumer</option></options></question><question><user_view>multi</user_view><q>Oscars: How many Oscars did Oppenheimer win at the 2024 Oscars? </q><short_answer>C</short_answer><long_answer/><options><option>5</option><option>6</option><option>7</option><option>8</option></options></question><question><user_view>letters</user_view><q>Oscars: Who is this former wrestler appearing entirely naked on stage to present an award at the 2024 Oscars? </q><short_answer>J</short_answer><long_answer>John Cena</long_answer><picture></picture></question></questions></round>